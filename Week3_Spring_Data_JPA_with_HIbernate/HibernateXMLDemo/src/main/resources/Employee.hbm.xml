<?xml version="1.0"?>

<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.example.model.Employee"
           table="employee">

        <id name="id"
            column="id"/>

        <property name="name"
                  column="name"/>

        <property name="salary"
                  column="salary"/>

    </class>

</hibernate-mapping>